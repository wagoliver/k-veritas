# ─── App ───────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ─── i18n ──────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en-US

# ─── Postgres (cadastro + sessão) ──────────────────────
DATABASE_URL=postgres://kveritas:kveritas@localhost:5432/kveritas

# ─── ClickHouse (telemetria de auth) ───────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=kveritas
CLICKHOUSE_USER=kveritas
CLICKHOUSE_PASSWORD=kveritas

# ─── Auth ──────────────────────────────────────────────
# Lista separada por ';' — a primeira assina, todas verificam
AUTH_JWT_SECRETS=dev-secret-change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_ACCESS_TTL_SECONDS=600
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
# 32 bytes base64 para AES-GCM do secret TOTP
AUTH_MFA_ENCRYPTION_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AUTH_PASSWORD_PEPPER=dev-pepper-change-me

# ─── Mail ──────────────────────────────────────────────
# console (loga no stdout) | smtp (futuro)
MAIL_TRANSPORT=console
MAIL_FROM=no-reply@k-veritas.local

# ─── IA (Análise automática de projetos) ──────────────
# Fallback usado quando a org não tem configuração salva em /settings/ai.
# A UI permite escolher "ollama" ou "openai-compatible" (LM Studio,
# llama.cpp, vLLM, OpenRouter, OpenAI, etc.).
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=16384
OLLAMA_TIMEOUT_MS=300000
